# Copy to .env.local and fill in your own values. Never commit .env.local.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (Project Settings -> API) — needed for auth, database, RLS
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection string (Dashboard -> Connect button, top of
# project page -> "URI" tab -> copy it and swap in your DB password where it
# says [YOUR-PASSWORD]). Only used locally to push migrations with the
# Supabase CLI -- not read by the app itself, not a real env var it loads.
SUPABASE_DB_URL=

# Groq (console.groq.com/keys) — sentiment, summarization, clustering labels
GROQ_API_KEY=

# Upstash Redis (console.upstash.com, REST API section) — rate limiting
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Hugging Face Inference API (huggingface.co/settings/tokens) — embeddings for clustering
HUGGINGFACE_API_TOKEN=
